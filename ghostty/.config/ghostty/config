# Ghostty config
#
# Upstream docs: https://ghostty.org/docs/config

# Match Alacritty settings in this repo.
font-family = "RobotoMono Nerd Font"
font-family-bold = "RobotoMono Nerd Font"
font-family-italic = "RobotoMono Nerd Font"
font-family-bold-italic = "RobotoMono Nerd Font"
font-size = 15

# Match Alacritty's family selection, then ask Ghostty for the true styles
# exposed by CoreText instead of treating full font names as families.
font-style = "Regular"
font-style-bold = "Bold"
font-style-italic = "Italic"
font-style-bold-italic = "Bold Italic"
font-synthetic-style = false
font-thicken = true
font-thicken-strength = 60

window-padding-x = 10
window-padding-y = 10

background-opacity = 0.9
faint-opacity = 0.78

# Match the Alacritty Tokyo Night palette in this repo.
background = #101217
foreground = #c0caf5
cursor-color = #c0caf5
cursor-text = #101217
selection-background = #283457
selection-foreground = #c0caf5
palette = 0=#15161e
palette = 1=#f7768e
