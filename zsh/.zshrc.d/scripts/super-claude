#!/usr/bin/env bash
set -euo pipefail

readonly config_dir="${SUPER_CLAUDE_CONFIG_DIR:-$HOME/.super-claude}"
readonly base_url="${SUPER_CLAUDE_BASE_URL:-http://infra.home.arpa:8317}"

claude_bin="$(command -v claude || true)"
if [[ -z "$claude_bin" ]]; then
  echo "super-claude: claude is not available on PATH." >&2
  exit 127
fi

: "${SUPER_CLAUDE_API_KEY:?super-claude: SUPER_CLAUDE_API_KEY is not set; add it to ~/.zshrc.d/keys.zsh}"

mkdir -p "$config_dir"
chmod 700 "$config_dir"

settings_file="$config_dir/settings.json"
if [[ ! -e "$settings_file" ]]; then
  settings_tmp="$(mktemp "${settings_file}.tmp.XXXXXX")"
  trap 'rm -f "$settings_tmp"' EXIT
  printf '%s\n' '{
  "model": "claude-anthropic-fable-5",
  "availableModels": [
    "claude-anthropic-fable-5",
    "claude-anthropic-opus-4.8",
    "claude-anthropic-sonnet-5",
    "claude-codex-gpt-5.6-sol",
    "claude-codex-gpt-5.6-terra",
    "claude-codex-gpt-5.6-luna",
    "claude-xai-grok-4.5",
    "claude-kimi-k3",
    "claude-opencode-glm-5.2"
  ]
}' > "$settings_tmp"
  chmod 600 "$settings_tmp"
  mv "$settings_tmp" "$settings_file"
  trap - EXIT
fi
chmod 600 "$settings_file"

export CLAUDE_CONFIG_DIR="$config_dir"
export ANTHROPIC_BASE_URL="$base_url"
unset ANTHROPIC_API_KEY
unset CLAUDE_CODE_USE_BEDROCK CLAUDE_CODE_USE_VERTEX CLAUDE_CODE_USE_FOUNDRY
export ANTHROPIC_AUTH_TOKEN="$SUPER_CLAUDE_API_KEY"

export ANTHROPIC_DEFAULT_FABLE_MODEL="claude-anthropic-fable-5"
export ANTHROPIC_DEFAULT_FABLE_MODEL_NAME="Fable 5"
export ANTHROPIC_DEFAULT_FABLE_MODEL_DESCRIPTION="Anthropic / Fable 5 through Super Claude"
export ANTHROPIC_DEFAULT_OPUS_MODEL="claude-anthropic-opus-4.8"
export ANTHROPIC_DEFAULT_OPUS_MODEL_NAME="Opus 4.8"
export ANTHROPIC_DEFAULT_OPUS_MODEL_DESCRIPTION="Anthropic / Opus 4.8 through Super Claude"
export ANTHROPIC_DEFAULT_SONNET_MODEL="claude-anthropic-sonnet-5"
export ANTHROPIC_DEFAULT_SONNET_MODEL_NAME="Sonnet 5"
export ANTHROPIC_DEFAULT_SONNET_MODEL_DESCRIPTION="Anthropic / Sonnet 5 through Super Claude"

if [[ -n "${SUPER_CLAUDE_DEFAULT_MODEL:-}" ]]; then
  export ANTHROPIC_MODEL="$SUPER_CLAUDE_DEFAULT_MODEL"
else
  unset ANTHROPIC_MODEL
fi

export CLAUDE_CODE_ENABLE_GATEWAY_MODEL_DISCOVERY=1
export CLAUDE_CODE_MAX_TOOL_USE_CONCURRENCY="${SUPER_CLAUDE_MAX_CONCURRENCY:-3}"

read_saved_model() {
  local line
  while IFS= read -r line; do
    if [[ "$line" =~ \"model\"[[:space:]]*:[[:space:]]*\"([^\"]+)\" ]]; then
      printf '%s\n' "${BASH_REMATCH[1]}"
      return 0
    fi
  done < "$settings_file"
  return 1
}

args=("$@")
has_model=0
has_resume=0
has_permission_mode=0
skip_default_model=0
explicit_model=""
skip_next_management_token=0

for ((i = 0; i < ${#args[@]}; i++)); do
  arg="${args[$i]}"
  if [[ "$skip_next_management_token" == 1 ]]; then
    skip_next_management_token=0
  else
    case "$arg" in
      --help|-h|--version|-v|auth|doctor|install|mcp|plugin|update) skip_default_model=1 ;;
    esac
  fi
  case "$arg" in
    --model)
      has_model=1
      if ((i + 1 < ${#args[@]})); then
        explicit_model="${args[$((i + 1))]}"
      fi
      ;;
    --model=*)
      has_model=1
      explicit_model="${arg#--model=}"
      ;;
    --print|-p) skip_next_management_token=1 ;;
    --resume|--resume=*|-r|--continue|-c) has_resume=1 ;;
    --dangerously-skip-permissions|--permission-mode|--permission-mode=*) has_permission_mode=1 ;;
  esac
done

launch_model="$explicit_model"
if [[ -z "$launch_model" && -n "${SUPER_CLAUDE_DEFAULT_MODEL:-}" ]]; then
  launch_model="$SUPER_CLAUDE_DEFAULT_MODEL"
fi

# Seed Fable only in the bootstrap file. Later ordinary launches honor the
# exact model saved by /model; resume/continue keeps the transcript model.
if [[ "$has_model" == 0 && "$has_resume" == 0 && "$skip_default_model" == 0 ]]; then
  if [[ -z "$launch_model" ]]; then
    if ! launch_model="$(read_saved_model)"; then
      launch_model="claude-anthropic-fable-5"
    fi
  fi
  args+=(--model "$launch_model")
fi

# A fixed launch-time override prevents Agent calls from silently switching a
# child back to a built-in Claude tier. Restart after /model to resynchronize.
if [[ "$skip_default_model" == 0 ]]; then
  if [[ -n "${SUPER_CLAUDE_SUBAGENT_MODEL:-}" ]]; then
    export CLAUDE_CODE_SUBAGENT_MODEL="$SUPER_CLAUDE_SUBAGENT_MODEL"
  elif [[ -n "${CLAUDE_CODE_SUBAGENT_MODEL:-}" ]]; then
    export CLAUDE_CODE_SUBAGENT_MODEL
  elif [[ -n "$launch_model" ]]; then
    export CLAUDE_CODE_SUBAGENT_MODEL="$launch_model"
  else
    unset CLAUDE_CODE_SUBAGENT_MODEL
  fi
else
  unset CLAUDE_CODE_SUBAGENT_MODEL
fi

if [[ "$has_permission_mode" == 0 ]]; then
  args+=(--permission-mode default)
fi

exec "$claude_bin" "${args[@]}"
